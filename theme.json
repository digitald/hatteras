{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "layout": {
      "contentSize": "720px",
      "wideSize": "1080px"
    },
    "color": {
      "palette": [
        {
          "name": "Pergamena",
          "slug": "pergamena",
          "color": "#F4EDE0"
        },
        {
          "name": "Inchiostro",
          "slug": "inchiostro",
          "color": "#1A1612"
        },
        {
          "name": "Inchiostro Soft",
          "slug": "inchiostro-soft",
          "color": "#4A4540"
        },
        {
          "name": "Oro",
          "slug": "oro",
          "color": "#B8942E"
        },
        {
          "name": "Percalina",
          "slug": "percalina",
          "color": "#7A2E2E"
        },
        {
          "name": "Ghiaccio",
          "slug": "ghiaccio",
          "color": "#E8EEF2"
        },
        {
          "name": "Nerofumo",
          "slug": "nerofumo",
          "color": "#2C2824"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Cormorant Garamond",
          "slug": "display",
          "fontFamily": "\"Cormorant Garamond\", Georgia, \"Times New Roman\", serif"
        },
        {
          "name": "Source Serif 4",
          "slug": "serif",
          "fontFamily": "\"Source Serif 4\", Georgia, \"Times New Roman\", serif"
        },
        {
          "name": "Source Sans 3",
          "slug": "sans",
          "fontFamily": "\"Source Sans 3\", system-ui, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "sm",
          "size": "0.875rem"
        },
        {
          "name": "Base",
          "slug": "base",
          "size": "1.125rem"
        },
        {
          "name": "Large",
          "slug": "lg",
          "size": "1.25rem"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "1.5rem"
        },
        {
          "name": "2XL",
          "slug": "2xl",
          "size": "2rem"
        },
        {
          "name": "3XL",
          "slug": "3xl",
          "size": "2.5rem"
        },
        {
          "name": "4XL",
          "slug": "4xl",
          "size": "3rem"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--pergamena)",
      "text": "var(--wp--preset--color--inchiostro)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--serif)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.7"
    }
  }
}
